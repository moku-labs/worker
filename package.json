{
  "name": "@moku-labs/worker",
  "version": "0.13.1",
  "description": "Cloudflare Worker framework for Moku — Durable Objects, Queues, R2, D1, and KV plugins that compose with Moku Web.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moku-labs/worker.git"
  },
  "homepage": "https://github.com/moku-labs/worker#readme",
  "bugs": {
    "url": "https://github.com/moku-labs/worker/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=24.0.0",
    "bun": ">=1.3.14"
  },
  "scripts": {
    "build": "tsdown",
    "validate": "publint && attw --pack . --profile node16",
    "lint": "biome check . && eslint .",
    "lint:fix": "biome check --write . && eslint --fix .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:coverage": "vitest run --project unit --project integration --coverage"
  },
  "dependencies": {
    "@moku-labs/common": "0.3.0",
    "@moku-labs/core": "1.5.0"
  },
  "peerDependencies": {
    "wrangler": ">=3"
  },
  "peerDependenciesMeta": {
    "wrangler": {
      "optional": true
    }
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.3",
    "@arethetypeswrong/core": "0.18.3",
    "@biomejs/biome": "2.4.16",
    "@cloudflare/workers-types": "4.20260617.1",
    "@types/bun": "1.3.14",
    "@vitest/coverage-istanbul": "4.0.18",
    "eslint": "9.39.3",
    "eslint-config-biome": "2.1.3",
    "eslint-plugin-jsdoc": "62.6.0",
    "eslint-plugin-sonarjs": "4.0.0",
    "eslint-plugin-unicorn": "63.0.0",
    "globals": "17.4.0",
    "jiti": "2.6.1",
    "lefthook": "2.1.1",
    "publint": "0.3.21",
    "tsdown": "0.22.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.58.0",
    "vitest": "4.0.18"
  }
}
